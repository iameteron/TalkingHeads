# Local development secrets.
# Copy this file to .env and fill the values you need.
# .env is intentionally ignored by git.

# Required for OpenRouter-backed agents, including ARC arc_image prompts.
OPENROUTER_API_KEY=

# Optional SOCKS/HTTP proxy for OpenRouter from restricted datacenter IPs.
# Example: socks5://user:pass@host:port
OPENROUTER_PROXY_URL=

# Required only when using Hugging Face Hub mode.
HF_TOKEN=

# App profile:
# - dev: expose debugging/settings controls.
# - demo: keep setup/model/prompt viewer, hide API key/prompt-edit/observation-format controls.
TALKINGHEADS_APP_PROFILE=dev

# Demo-only defaults. Leave blank to use Claude Sonnet 4.5.
TALKINGHEADS_DEMO_AGENT_MODEL=anthropic/claude-sonnet-4.5
TALKINGHEADS_DEMO_ARC_OBS_FORMAT=arc_image

# Optional: override Python for play_web scripts (default: repo .venv/bin/python).
# PLAY_WEB_PYTHON=
